generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tournament {
  id                String   @id @default(cuid())
  name              String
  sport             String   @default("")
  startDate         String   @default("")
  endDate           String   @default("")
  location          String   @default("")
  scheduleIncrement Int      @default(50)
  dates             String   @default("[]")
  payRates          String   @default("{\"youth\":50,\"hs\":60,\"college\":70,\"scorekeeper\":15,\"athletic_trainer\":25,\"field_ops\":20,\"assigner\":10}")
  logoUrl               String @default("")
  registrationPricing   String @default("{\"tier1\":1495,\"tier1Max\":3,\"tier2\":1450,\"tier2Max\":6,\"tier3\":1395,\"sevenVSeven\":1095}")
  registrationDivisions String @default("[\"Boys 2030\",\"Boys 2029\",\"Boys 2028\",\"Boys 2027\",\"Boys 2026\",\"Boys 2025\",\"Boys 2024\",\"Boys 2023\",\"Girls 2030\",\"Girls 2029\",\"Girls 2028\",\"Girls 2027\",\"Girls 2026\",\"Girls 2025\",\"Girls 2024\",\"Girls 2023\",\"HS Boys JV\",\"HS Boys Varsity\",\"HS Girls JV\",\"HS Girls Varsity\"]")
  divisionRules     String   @default("{}")
  teamRegEnabled           Boolean  @default(true)
  individualRegEnabled     Boolean  @default(false)
  individualRegDescription String   @default("")
  individualRegTiers       String   @default("[]")
  individualRegPositions   String   @default("[]")
  individualRegSizes       String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  games              Game[]
  availabilities     Availability[]
  rosterEntries      RosterEntry[]
  paymentRecords      PaymentRecord[]
  teamRegistrations   TeamRegistration[]
  playerRegistrations PlayerRegistration[]
  transactions        TournamentTransaction[]
  individualRegistrations IndividualRegistration[]
}

model Game {
  id             String   @id @default(cuid())
  tournamentId   String
  gameNumber     String
  date           String
  startTime      String
  division       String
  pool           String?
  location       String
  team1          String
  team2          String
  score1         Int?
  score2         Int?
  refCount       Int      @default(2)
  isChampionship Boolean  @default(false)
  isCanceled     Boolean  @default(false)
  createdAt      DateTime @default(now())

  tournament  Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([tournamentId])
  @@index([date, startTime])
}

model Worker {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  certLevel       String   @default("youth")
  association      String   @default("")
  defaultRole     String   @default("ref")
  isAssigner      Boolean  @default(false)
  gender          String   @default("both")
  photoUrl        String?
  payRateOverride Float?
  hourlyRate      Float?
  roles           String   @default("[]")
  payMethod       String   @default("check")
  payHandle       String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  availabilities Availability[]
  assignments    Assignment[]
  timeEntries    TimeEntry[]
  rosterEntries  RosterEntry[]
  paymentRecords PaymentRecord[]
}

model RosterEntry {
  id           String   @id @default(cuid())
  workerId     String
  tournamentId String
  gameTarget   Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())

  worker     Worker     @relation(fields: [workerId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([workerId, tournamentId])
  @@index([tournamentId])
}

model Availability {
  id           String @id @default(cuid())
  workerId     String
  tournamentId String
  date         String
  timeSlots    String @default("[]")

  worker     Worker     @relation(fields: [workerId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([workerId, tournamentId, date])
  @@index([tournamentId])
}

model TimeEntry {
  id           String   @id @default(cuid())
  workerId     String
  tournamentId String
  date         String
  clockIn      String?
  clockOut     String?
  hoursManual  Float?
  notes        String?
  isManualEdit Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, tournamentId])
  @@index([tournamentId])
}

model Assignment {
  id        String   @id @default(cuid())
  gameId    String
  workerId  String
  role      String
  payRate   Float
  createdAt DateTime @default(now())

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([gameId, role])
  @@index([gameId])
  @@index([workerId])
}

model AuditLog {
  id           String   @id @default(cuid())
  tournamentId String
  action       String
  deletedBy    String
  detail       String?
  createdAt    DateTime @default(now())

  @@index([tournamentId])
}

model TeamRegistration {
  id              String   @id @default(cuid())
  tournamentId    String
  clubName        String
  clubContact     String
  contactEmail    String
  contactPhone    String
  clubBasedIn     String   @default("")
  clubWebsite     String   @default("")
  numTeams        Int      @default(1)
  needsHotel      String   @default("No")
  paymentMethod   String   @default("check")
  notes           String?
  invoiceAmount   Float    @default(0)
  discountAmount  Float    @default(0)
  discountNote    String   @default("")
  clubLogoUrl     String   @default("")
  qboInvoiceId    String   @default("")
  qboCustomerId   String   @default("")
  createdAt       DateTime @default(now())

  tournament Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams      RegisteredTeam[]
  payments   RegistrationPayment[]

  @@index([tournamentId])
}

model RegistrationPayment {
  id             String   @id @default(cuid())
  registrationId String
  amount         Float
  method         String   @default("check")
  checkNumber    String   @default("")
  receivedAt     String
  notes          String   @default("")
  createdAt      DateTime @default(now())

  registration TeamRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model RegisteredTeam {
  id             String @id @default(cuid())
  registrationId String
  clubName       String
  teamName       String
  division       String
  coachName      String
  coachPhone     String
  coachEmail     String
  logoUrl        String @default("")

  registration TeamRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model PlayerRegistration {
  id                   String   @id @default(cuid())
  tournamentId         String
  playerName           String
  playerEmail          String   @default("")
  usLacrosseNumber     String
  gender               String
  dob                  String   @default("")
  grade                String
  teamClubName         String
  jerseyNumber         String   @default("")
  parentName           String
  parentEmail          String
  parentPhone          String
  parent2Name          String   @default("")
  parent2Email         String   @default("")
  parent2Phone         String   @default("")
  emergencyContactName  String
  emergencyContactPhone String
  waiverSignature      String
  needsHotel           String   @default("")
  wantsUpdates         Boolean  @default(false)
  createdAt            DateTime @default(now())

  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  parentLinks  ParentPlayerLink[]

  @@index([tournamentId])
}

model PaymentRecord {
  id           String   @id @default(cuid())
  workerId     String
  tournamentId String
  amount       Float
  method       String   @default("check")
  paidAt       DateTime @default(now())
  notes        String?
  paidBy       String?

  worker     Worker     @relation(fields: [workerId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([tournamentId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("viewer")
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model UserTournamentFollow {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  createdAt    DateTime @default(now())

  @@unique([userId, tournamentId])
  @@index([userId])
}

model UserTeamFollow {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  teamName     String
  createdAt    DateTime @default(now())

  @@unique([userId, tournamentId, teamName])
  @@index([userId])
}

model CoachProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  tournamentId String
  teamName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model ClubDirectorLink {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  clubName     String
  createdAt    DateTime @default(now())

  @@unique([userId, tournamentId, clubName])
  @@index([userId])
}

model ParentPlayerLink {
  id                   String             @id @default(cuid())
  userId               String
  playerRegistrationId String
  createdAt            DateTime           @default(now())

  playerReg PlayerRegistration @relation(fields: [playerRegistrationId], references: [id], onDelete: Cascade)

  @@unique([userId, playerRegistrationId])
  @@index([userId])
}

model TournamentTransaction {
  id           String   @id @default(cuid())
  tournamentId String
  type         String   // 'income' | 'expense'
  category     String
  description  String
  amount       Float
  method       String   @default("check")
  date         String
  notes        String   @default("")
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([type])
}

model StaffInvite {
  id           String    @id @default(cuid())
  token        String    @unique
  email        String
  name         String?
  tournamentId String?
  usedAt       DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([token])
  @@index([email])
}

model Pool {
  id           String   @id @default(cuid())
  tournamentId String
  division     String
  name         String
  teamNames    String   @default("[]")
  createdAt    DateTime @default(now())

  @@index([tournamentId, division])
}

model Bracket {
  id           String        @id
  tournamentId String
  division     String
  format       String        @default("single")
  teamCount    Int           @default(8)
  seeds        String        @default("{}")
  createdAt    DateTime      @default(now())
  games        BracketGame[]

  @@index([tournamentId, division])
}

model BracketGame {
  id          String   @id
  bracketId   String
  gameNumber  Int
  round       Int
  section     String   @default("winners")
  team1Source String   @default("")
  team2Source String   @default("")
  label       String   @default("")
  team1       String   @default("")
  team2       String   @default("")
  score1      Int?
  score2      Int?
  winner      String   @default("")
  loser       String   @default("")
  field       String   @default("")
  startTime   String   @default("")
  gameDate    String   @default("")
  createdAt   DateTime @default(now())

  bracket Bracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)

  @@index([bracketId])
}

model IndividualRegistration {
  id                   String   @id @default(cuid())
  tournamentId         String
  firstName            String
  lastName             String
  email                String
  phone                String   @default("")
  position             String
  numberRequest        String   @default("")
  jerseySize           String
  shortsSize           String
  usLacrosseNumber     String   @default("")
  dateOfBirth          String   @default("")
  guardianName         String   @default("")
  guardianPhone        String   @default("")
  guardianEmail        String   @default("")
  emergencyContactName  String  @default("")
  emergencyContactPhone String  @default("")
  emergencyRelationship String  @default("")
  medicalNotes         String   @default("")
  waiverSigned         Boolean  @default(false)
  waiverSignature      String   @default("")
  feeTierId            String
  feeTierName          String
  feeTierAmount        Float
  paymentStatus        String   @default("pending")
  stripePaymentIntent  String?
  stripeSessionId      String?
  createdAt            DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([email])
}

model OrgPaymentProvider {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // 'stripe' | 'quickbooks' | 'paypal'
  enabled   Boolean  @default(true)
  config    String   @default("{}") // AES-encrypted JSON
  mode      String   @default("live") // 'test' | 'live'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String   @default("")
  contactEmail String  @default("")
  contactPhone String  @default("")
  website     String   @default("")

  // Payment instructions shown on public registration forms
  achBankName      String @default("")
  achRoutingNumber String @default("")
  achAccountNumber String @default("")
  paypalEmail      String @default("")
  zelleHandle      String @default("")
  checkPayableTo   String @default("")
  checkAddress     String @default("")

  // Subscription
  subscriptionTier   String @default("starter") // starter | pro | enterprise
  subscriptionStatus String @default("active")  // active | past_due | canceled
  stripeCustomerId   String @default("")
  stripeSubscriptionId String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
