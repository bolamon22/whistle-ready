# Whistle Ready — local preview environment template
# Copy this file to ".env" (same folder) and paste the values from your
# Vercel project: Settings -> Environment Variables. Never commit the real .env.

# --- Database (required for most pages) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Auth (required to log in locally) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Email confirmations (Resend) ---
RESEND_API_KEY=
INVITE_FROM_EMAIL=

# --- Payments (Stripe) — needed for registration/checkout ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ACCOUNT_ID=

# --- Optional integrations ---
ANTHROPIC_API_KEY=
ENCRYPTION_KEY=
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
