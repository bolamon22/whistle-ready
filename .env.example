# Whistle Ready — local preview environment template
# Copy this file to ".env" (same folder) and paste the values from your
# Vercel project: Settings -> Environment Variables. Never commit the real .env.

# --- Database (required for most pages) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Auth (required to log in locally) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Email (SendGrid) — all transactional email goes through src/lib/email.ts ---
# API key: SendGrid > Settings > API Keys (Restricted Access, "Mail Send" only).
SENDGRID_API_KEY=
# Sender must be on a domain authenticated in SendGrid (Settings > Sender Authentication),
# otherwise mail silently lands in spam or is rejected.
EMAIL_FROM=noreply@whistleready.app
EMAIL_FROM_NAME=Whistle Ready
# Legacy fallback — only read if EMAIL_FROM is unset. Safe to remove once deployed.
INVITE_FROM_EMAIL=

# --- Payments (Stripe) — needed for registration/checkout ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ACCOUNT_ID=

# --- Optional integrations ---
ANTHROPIC_API_KEY=
ENCRYPTION_KEY=
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
